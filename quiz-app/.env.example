# ── Google Sheets (required for Sheets mode) ──────────────────────────────────
# 1. console.cloud.google.com → create project → enable Google Sheets API
# 2. Create a Service Account → download the JSON key file
# 3. Share your spreadsheet with the service account email (Editor access)
# 4. Copy the three values below from the JSON key and the spreadsheet URL

GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private_key value from the JSON key exactly as-is (with literal \n sequences).
# On Vercel, paste the raw key with real newlines in the Environment Variables UI — both work.
GOOGLE_PRIVATE_KEY=

# ── Deployment notes ───────────────────────────────────────────────────────────
# This app is deployed on Vercel (quiz-app/ is the Vercel root directory).
# The frontend and API live on the same domain, so no CORS config is needed.
#
# Set the three GOOGLE_* vars above in Vercel → Project Settings → Environment Variables.
# No other env vars are required for production.
#
# For local development, copy this file to .env and fill in the Google values.
# Leave GOOGLE_* blank to run entirely off CSV fallback files (server/data/*.csv).
