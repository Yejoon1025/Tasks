# ── Google Sheets (server — required for Sheets mode) ────────────────────────
# 1. console.cloud.google.com → create project → enable Google Sheets API
# 2. Create a Service Account → download the JSON key
# 3. Share your spreadsheet with the service account email (Editor access)
# 4. Copy the three values below from the JSON key file and the spreadsheet URL

GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private_key value exactly as it appears in the JSON (with literal \n sequences)
# On Render, paste the raw key with real newlines instead — both work.
GOOGLE_PRIVATE_KEY=

# ── CORS (server — required in production) ───────────────────────────────────
# Set to your GitHub Pages URL so the server only accepts requests from your app.
# Leave blank in local dev (all origins are allowed when unset).
CORS_ORIGIN=https://<username>.github.io

# ── GitHub repository Secrets (not in this file — set in repo Settings) ──────
# VITE_API_BASE   = https://<your-app>.onrender.com
# VITE_BASE_PATH  = /<repo-name>/   (or / for a username.github.io root repo)
